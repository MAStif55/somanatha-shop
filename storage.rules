rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ─── Backup archives — NEVER publicly accessible ────────────────────────
    // Access is granted exclusively via time-limited Signed URLs generated
    // by the Firebase Admin SDK inside the createBackup Cloud Function.
    // This rule must be listed BEFORE the catch-all read rule below.
    match /backups/{allPaths=**} {
      allow read, write: if false;
    }

    // ─── Public assets ──────────────────────────────────────────────────────
    // Product images, videos and other public media are readable by anyone.
    match /{allPaths=**} {
      allow read: if true;
    }

    // ─── Authenticated uploads ──────────────────────────────────────────────
    match /uploads/{allPaths=**} {
      allow write: if request.auth != null;
    }

    // Allow video uploads for Live Photo feature
    match /videos/{allPaths=**} {
      allow write: if request.auth != null;
    }
  }
}
