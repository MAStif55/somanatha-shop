#!/bin/bash
TARGET="/var/www/levprav"
GIT_DIR="/var/repo/levprav.git"

while read oldrev newrev ref; do
    if [[ $ref = refs/heads/main ]]; then
        echo "============================================"
        echo "  LevPrav Auto-Deploy: Received push"
        echo "============================================"
        
        echo ">>> Checking out latest code..."
        git --work-tree=$TARGET --git-dir=$GIT_DIR checkout -f main

        echo ">>> Installing dependencies..."
        cd $TARGET
        npm ci

        echo ">>> Building Next.js application..."
        npm run build

        echo ">>> Restarting PM2 instance on Port 3002..."
        pm2 restart levprav || pm2 start npm --name levprav -- start -- -p 3002

        echo "============================================"
        echo "  Deployment Complete!"
        echo "============================================"
    fi
done
